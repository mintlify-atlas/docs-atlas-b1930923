  "keyFeatures": [
    "Automatic camera discovery via Rhombus API",
    "Web UI for enabling/disabling RTSP streams per camera",
    "Up to 10 concurrent RTSP streams with stream copy (no transcoding)",
    "Automatic stream recovery on failure with configurable retry logic",
    "Persistent stream state across reboots via JSON state store",
    "Systemd-native deployment with watchdog integration",
    "Configurable nightly auto-update window",
    "Raspberry Pi SD card image builder (cloud-init and pre-baked modes)",
    "FFmpeg-based stream pull and MediaMTX RTSP rebroadcast",
    "Deterministic RTSP path slugs from camera names"
  ],
  "publicApiSurface": [
    "GET /api/auth/status",
    "GET /api/settings",
    "POST /api/settings/api-key",
    "PUT /api/settings/update-schedule",
    "POST /api/settings/discovery/refresh",
    "GET /api/cameras",
    "GET /api/streams",
    "POST /api/streams/{uuid}/enable",
    "POST /api/streams/{uuid}/disable",
    "GET /api/system/status"
  ]
